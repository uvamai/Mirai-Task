# API
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://mirai:mirai@localhost:55432/mirai_tasker
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars!!
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
BILLING_MODE=mock
# Plan code for new registrations (must match subscription_plans.code)
DEFAULT_SIGNUP_PLAN_CODE=starter
CORS_ORIGIN=http://localhost:5173

# Dev-only tenant resolution (never rely on this in production)
ALLOW_X_TENANT_ID=true

# Stripe (when BILLING_MODE=stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Return URLs for Checkout / Customer Portal
# PUBLIC_WEB_URL=http://localhost:5173

# File uploads (API cwd-relative or absolute)
# STORAGE_DIR=storage

# Socket.IO (same port as API; proxy /socket.io from Vite in dev)
# SOCKET_ENABLED=true

# Optional: delete activity_logs older than N days (scheduled from API process). Omit or 0 to disable.
# ACTIVITY_LOG_RETENTION_DAYS=365

# Max span (days) for GET /admin/audit/export (default 366)
# AUDIT_EXPORT_MAX_DAYS=366

# SAML readiness probe only (/auth/sso/status). Full SSO login is not enabled in the scaffold.
# SAML_ENTRY_POINT=
# SAML_ISSUER=
# SAML_IDP_CERT=

# OIDC readiness (status only until callback routes are wired)
# OIDC_ISSUER=
# OIDC_CLIENT_ID=

# Public intake captcha (optional; when set, intake requires a token)
# TURNSTILE_SECRET_KEY=
# HCAPTCHA_SECRET_KEY=
# RECAPTCHA_SECRET_KEY=
# PUBLIC_INTAKE_MAX_PER_IP_PER_HOUR=40

# Invitations abuse limits
# INVITE_CREATE_MAX_PER_HOUR=30
# MAX_PENDING_INVITES_PER_TENANT=100
